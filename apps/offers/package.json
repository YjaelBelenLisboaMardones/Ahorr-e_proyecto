    "next": "16.1.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
