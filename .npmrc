# PNPM Configuration — Ahorr-E Monorepo
# ═════════════════════════════════════════════════════════════════════════════
# Garantiza aislamientos de dependencias y hoisting selectivo para Edge Runtime.
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# ESTRATEGIA DE HOISTING
# ─────────────────────────────────────────────────────────────────────────────
# `shamefully-hoist`: Evita duplicación de dependencias peerDependencies
# (TypeScript, ESLint). Aceptable en monorepos con versionado centralizado.
# Riesgo mitigado: cada servicio declara sus devDependencies explícitamente.
shamefully-hoist=true

# ─────────────────────────────────────────────────────────────────────────────
# STRICT PEER DEPENDENCIES
# ─────────────────────────────────────────────────────────────────────────────
# Fuerza resolución correcta de peer deps (Next.js ↔ React, Supabase ↔ Auth).
# Previene incompatibilidades de runtime que quiebren Edge Functions.
strict-peer-dependencies=true

# ─────────────────────────────────────────────────────────────────────────────
# NODE LINKER (Compatibilidad Edge Runtime)
# ─────────────────────────────────────────────────────────────────────────────
# `isolated`: Crea node_modules aislados por workspace (recomendado para Edge).
# Evita que Vercel/Supabase Edge Functions resuelvan dependencias inesperadas.
node-linker=isolated

# ─────────────────────────────────────────────────────────────────────────────
# RESOLUCIÓN DE DEPENDENCIAS
# ─────────────────────────────────────────────────────────────────────────────
# Auto-deduplica dependencias idénticas entre workspaces (sin duplicar en raíz).
# RNF7 (Escalabilidad Independiente): cada servicio obtiene su copia aislada.
auto-install-peers=true

# ─────────────────────────────────────────────────────────────────────────────
# REGISTRY Y SEGURIDAD
# ─────────────────────────────────────────────────────────────────────────────
# Registry estándar (npm). Sobre-escribe con .npmrc.local si se usa privada.
registry=https://registry.npmjs.org/
