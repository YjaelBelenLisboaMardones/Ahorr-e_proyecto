{
  "name": "mi-proyecto-ahorro",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r --parallel run build",
    "build:deps": "pnpm -r run build --filter='@ahorr-e/schemas,@ahorr-e/types'",
    "build:services": "pnpm -r run build --filter='./services/*'",
    "build:app": "pnpm -C app run build",
    "start": "pnpm -C app run start",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint -- --fix",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm -C app run test:e2e",
    "db:generate": "pnpm -C app run prisma generate",
    "db:push": "pnpm -C app run prisma db push",
    "db:studio": "pnpm -C app run prisma studio",
    "clean": "pnpm -r exec rm -rf node_modules dist .next && rm -rf node_modules",
    "install:ci": "pnpm install --frozen-lockfile",
    "precommit": "pnpm run lint && pnpm run test"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.40",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "vitest-mock-extended": "^4.0.0"
  }
}
